# DocMind Docker Deployment - Environment Configuration
# Copy this file to .env.docker and fill in your values
# NEVER commit .env.docker to version control

# --- Security (REQUIRED) ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
JWT_SECRET_KEY=

# --- AI Models (REQUIRED) ---
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://open.bigmodel.cn/api/paas/v4/
DEEPSEEK_MODEL=glm-4-flash

EMBEDDING_API_KEY=
EMBEDDING_API_URL=https://open.bigmodel.cn/api/paas/v4/
EMBEDDING_MODEL=embedding-3
VECTOR_DIMENSION=2048

RERANK_API_KEY=
RERANK_API_URL=https://open.bigmodel.cn/api/paas/v4/
RERANK_MODEL=rerank

# --- Database ---
MYSQL_ROOT_PASSWORD=changeme_root_pw
MYSQL_DATABASE=docmind
MYSQL_USER=docmind
MYSQL_PASSWORD=docmind123

# --- Redis ---
REDIS_PASSWORD=

# --- MinIO ---
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=docmind

# --- Application ---
DEBUG=false
LOG_LEVEL=INFO
ENABLE_DEMO_ACCOUNT=true
ENABLE_ENSURE_DEMO_ENDPOINT=false
EXPOSE_EXCEPTION_DETAIL=false
AI_MAX_TOKENS=10000
AI_STREAM_TIMEOUT=120

# --- Monitoring ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123
