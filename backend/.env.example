# ============================================================
# DocMind RAG 知识库系统 - 环境配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# --- 安全 (必填，否则服务无法启动) ---
# 生成命令: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# --- AI 模型 (必填) ---
# Chat 模型 (DeepSeek / OpenAI 兼容)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_API_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
AI_MAX_TOKENS=10000

# Embedding 模型
EMBEDDING_API_KEY=sk-your-embedding-key-here
EMBEDDING_API_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_DIMENSION=1536

# Reranker (可选)
# RERANK_API_KEY=sk-your-rerank-key
# RERANK_API_URL=https://api.deepseek.com
# RAG_ENABLE_RERANKER=true

# --- 基础设施 (Docker 默认值) ---
DATABASE_URL=mysql+aiomysql://root:root@localhost:3306/docmind_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

ELASTICSEARCH_HOSTS=["http://localhost:9200"]
ELASTICSEARCH_INDEX_NAME=docmind_knowledge

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_FILE_PROCESSING_TOPIC=file-processing

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=docmind
MINIO_SECURE=false

# --- 应用 ---
DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=false
ENABLE_DEMO_ACCOUNT=true
EXPOSE_EXCEPTION_DETAIL=false
ENABLE_ENSURE_DEMO_ENDPOINT=false

# --- 文件上传 ---
MAX_FILE_SIZE=104857600
USER_STORAGE_LIMIT_BYTES=10737418240

# --- 监控告警 ---
ENABLE_MONITORING=true
MONITORING_INTERVAL=60
SLOW_REQUEST_THRESHOLD_MS=1200
ALERT_ERROR_RATE_PERCENT=5.0
ALERT_P95_MS=1200.0
ALERT_ACTIVE_CONNECTIONS=200
# ALERT_WEBHOOK_TOKEN=your-webhook-token

# --- 限流 ---
ENABLE_RATE_LIMIT=true
RATE_LIMIT_REQUESTS_PER_MINUTE=10000
RATE_LIMIT_WINDOW_SECONDS=60

# --- 隐私 ---
ENABLE_PII_MASKING=true
