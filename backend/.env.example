# ============================================================
# DocMind RAG 知识库系统 - 环境配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# --- 安全 (必填，否则服务无法启动) ---
# 生成命令: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# --- AI 模型 (必填) ---
# Chat 模型 (DeepSeek / OpenAI 兼容)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_API_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Embedding 模型
EMBEDDING_API_KEY=sk-your-embedding-key-here
EMBEDDING_API_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_DIMENSION=1536

# --- 基础设施 (Docker 默认值) ---
DATABASE_URL=mysql+aiomysql://root:root@localhost:3306/paicongming_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

ELASTICSEARCH_HOSTS=["http://localhost:9200"]
ELASTICSEARCH_INDEX_NAME=paicongming_knowledge

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_FILE_PROCESSING_TOPIC=file-processing

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=paicongming
MINIO_SECURE=false

# --- 应用 ---
DEBUG=false
LOG_LEVEL=INFO
ENABLE_DEMO_ACCOUNT=true
EXPOSE_EXCEPTION_DETAIL=false
