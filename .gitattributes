# Auto detect text files and perform LF normalization
* text=auto

# Python
*.py text eol=lf

# Web
*.js text eol=lf
*.ts text eol=lf
*.vue text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.mts text eol=lf

# Config / scripts
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.md text eol=lf

# Windows batch
*.bat text eol=crlf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pkl binary
